# Turso (production): get these from https://turso.tech after creating a database
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# Local dev: uses a local SQLite file
# TURSO_DATABASE_URL=file:local.db
# TURSO_AUTH_TOKEN=

# Optional: enables the real Claude-powered problem analysis on the
# "Describe Problem" step (/api/analyze). Without it, a built-in
# keyword heuristic is used instead, so the feature still works.
# ANTHROPIC_API_KEY=sk-ant-...
